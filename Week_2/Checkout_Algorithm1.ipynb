   "source": [
    "\n",
    " INPUT product prices\n",
    " COMPUTE Total\n",
    " IF Total > 500,000\n",
    "    Discount = Total + (3% * Total)\n",
    "    Final Price = Discount\n",
    "ELSE \n",
    "    Final Price = Total\n",
    " PRINT Final Price    \n"
   ]
