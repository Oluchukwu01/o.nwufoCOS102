   "source": [
    "print(\"Compound Interest Calculator\")\n",
    "P = float(input(\"Principal:\"))\n",
    "R = float(input(\"Rate: \"))\n",
    "t = float(input(\"Time: \"))\n",
    "n = float(input(\"Number of times: \"))\n",
    "C = P * (1 + ((R/n)) ** (n*t))\n",
    "print(\"Compound Interest = \", C)"
   ]
  },
