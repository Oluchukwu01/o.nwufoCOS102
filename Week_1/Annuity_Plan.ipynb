   "source": [
    "print(\"Compound Interest Calculator\")\n",
    "PMT = float(input(\"Payment per period:\"))\n",
    "R = float(input(\"Rate: \"))\n",
    "t = float(input(\"Time: \"))\n",
    "n = float(input(\"Number of payments: \"))\n",
    "FV = PMT * ((1 + ((R/n)) ** (n*t)))/(R/n)\n",
    "print(\"Annuity Plan = \", FV)"
   ]
  },
