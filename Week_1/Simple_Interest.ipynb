   "source": [
    "print(\"Simple Interest Calculator\")\n",
    "P = float(input(\"Principal:\"))\n",
    "R = float(input(\"Rate: \"))\n",
    "T = float(input(\"Time: \"))\n",
    "A = P * (1 + ((R/100) * T))\n",
    "print(\"Simple Interest = \", A)"
   ]
